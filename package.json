{
  "name": "letters",
  "version": "0.2.0",
  "description": "Letters — A focused writing app",
  "author": {
    "name": "Christopher Könitz",
    "email": "christopher@koenitz.io"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:1420 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:mac-arm": "npm run build && electron-builder --mac --arm64",
    "dist:mac-x64": "npm run build && electron-builder --mac --x64"
  },
  "dependencies": {
    "@tiptap/core": "^2.10.0",
    "@tiptap/extension-placeholder": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "marked": "^12.0.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "io.letters.app",
    "productName": "Letters",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "icon": "src-tauri/icons/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "dmg", "arch": ["x64"] }
      ]
    },
    "dmg": {
      "title": "Letters ${version}"
    },
    "win": {
      "icon": "src-tauri/icons/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "src-tauri/icons/icon.png",
      "category": "Office",
      "target": ["AppImage", "deb"]
    }
  }
}
